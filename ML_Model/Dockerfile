# ============================================================
# STGNN DEPLOYMENT DOCKERFILE
# ============================================================

FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source files
COPY model.py .
COPY recommendation.py .
COPY app.py .

# Copy trained model weights
COPY stgnn_traffic_model.pth .

# Copy scalers (generated by train_stgnn.py)
COPY x_scaler.pkl .
COPY event_scaler.pkl .
COPY y_scaler.pkl .

# Copy adjacency matrices (generated by train_stgnn.py)
COPY A_road.npy .
COPY A_traffic.npy .
COPY A_event.npy .

EXPOSE 8080

ENV MODEL_PATH=stgnn_traffic_model.pth
ENV X_SCALER_PATH=x_scaler.pkl
ENV EVENT_SCALER_PATH=event_scaler.pkl
ENV Y_SCALER_PATH=y_scaler.pkl
ENV A_ROAD_PATH=A_road.npy
ENV A_TRAFFIC_PATH=A_traffic.npy
ENV A_EVENT_PATH=A_event.npy

CMD ["python", "app.py"]
